        ".read": "auth != null && (auth.uid === $childUid || root.child('locations').child($childUid).child('meta').child('parentUid').val() === auth.uid)",
        ".write": false
      }
    },
    "zoneEventsByChild": {
      "$childUid": {
        ".read": "auth != null && (auth.uid === $childUid || root.child('locations').child($childUid).child('meta').child('parentUid').val() === auth.uid)",
        ".write": "auth != null && auth.uid === $childUid"
      }
    },
    "zonePresenceByChild": {
